APP_NAME=AuditFlow AI Backend
APP_ENV=development
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/auditflow
QDRANT_URL=http://qdrant:6333
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
AGENT_PROVIDER=openai
AGENT_MODEL=gpt-4.1-mini
AGENT_TEMPERATURE=0.1
AGENT_TIMEOUT_SECONDS=60
AGENT_MAX_OUTPUT_TOKENS=4096
UPLOAD_STORAGE_DIR=storage/uploads
DOCUMENT_METADATA_PATH=storage/document_metadata.json
ANALYSIS_REPORT_PATH=storage/analysis_reports.json
MAX_UPLOAD_SIZE_BYTES=10485760
KNOWLEDGE_COLLECTION_NAME=auditflow_knowledge
EMBEDDING_VECTOR_SIZE=64
RETRIEVAL_TOP_K=5
POSTGRES_DB=auditflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
