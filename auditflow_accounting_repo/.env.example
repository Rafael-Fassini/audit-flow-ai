APP_NAME=AuditFlow AI Backend
APP_ENV=development
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/auditflow
QDRANT_URL=http://qdrant:6333
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
UPLOAD_STORAGE_DIR=storage/uploads
DOCUMENT_METADATA_PATH=storage/document_metadata.json
MAX_UPLOAD_SIZE_BYTES=10485760
KNOWLEDGE_COLLECTION_NAME=auditflow_knowledge
EMBEDDING_VECTOR_SIZE=64
RETRIEVAL_TOP_K=5
